{
  "appId": "app.vibecode.mobile2",
  "appName": "vibecode",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "android": {
    "buildOptions": {
      "keystorePath": "releases/vibecode.keystore",
      "keystoreAlias": "vibecode",
