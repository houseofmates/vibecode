# Hermes Web UI Configuration
# Copy this file to .env and customize values

# Network
#HERMES_WEBUI_HOST=127.0.0.1
#HERMES_WEBUI_PORT=8787

# Security
#HERMES_WEBUI_PASSWORD=your_secure_password_here

# Directories
#HERMES_WEBUI_STATE_DIR=~/.hermes/webui
#HERMES_WEBUI_DEFAULT_WORKSPACE=~/workspace

# Hermes agent integration
#HERMES_WEBUI_AGENT_DIR=/path/to/hermes-agent
#HERMES_HOME=~/.hermes

# TLS/HTTPS (optional)
#HERMES_WEBUI_TLS_CERT=/path/to/cert.pem
#HERMES_WEBUI_TLS_KEY=/path/to/key.pem

# Model defaults
#HERMES_WEBUI_DEFAULT_MODEL=openai/gpt-5.4-mini

# Override config path (optional)
#HERMES_CONFIG_PATH=~/.hermes/config.yaml