APPDIR=$ORIGIN
APPIMAGE_UUID=8JCF8fZ
APPDIR_EXEC_PATH=$APPDIR/usr/bin/vibecode
APPDIR_EXEC_ARGS=$@
XDG_DATA_DIRS=$APPDIR/usr/local/share:$APPDIR/usr/share:$XDG_DATA_DIRS
XDG_CONFIG_DIRS=$APPDIR/etc/xdg:$XDG_CONFIG_DIRS
APPDIR_LIBRARY_PATH=$APPDIR/lib:$APPDIR/lib/x86_64-linux-gnu:$APPDIR/usr/lib/python3/dist-packages:$APPDIR/usr/lib/x86_64-linux-gnu:$APPDIR/usr/lib/x86_64-linux-gnu/krb5/plugins/preauth:$APPDIR/usr/lib/x86_64-linux-gnu/pulseaudio:$APPDIR/usr/lib/x86_64-linux-gnu/sasl2:$APPDIR/lib/x86_64
PATH=$APPDIR:$APPDIR/usr/bin:$APPDIR/usr/lib/git-core:$APPDIR/usr/lib/python3.10:$APPDIR/usr/lib/python3.10/encodings:$APPDIR/usr/lib/python3.11/lib2to3/pgen2:$APPDIR/usr/share/git-core/contrib/hooks:$APPDIR/usr/share/git-core/templates/hooks:$APPDIR/usr/share/gitweb:$APPDIR/usr/share/python3:$APPDIR/usr/share/python3/runtime.d:$PATH
GTK_EXE_PREFIX=$APPDIR/usr
GTK_DATA_PREFIX=$APPDIR/usr
APPDIR_LIBC_LIBRARY_PATH=$APPDIR/runtime/compat/lib64:$APPDIR/runtime/compat/lib/x86_64-linux-gnu:$APPDIR/runtime/compat/usr/lib/x86_64-linux-gnu:$APPDIR/runtime/compat/usr/lib/x86_64-linux-gnu/gconv
APPDIR_LIBC_VERSION=2.35
