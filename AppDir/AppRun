#!/bin/bash
# VibeCode - AppRun (runs from local or remote codebase)
set -e

APPDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Preserve system PATH to access system git
export PATH="/usr/local/bin:/usr/bin:/bin:$APPDIR/usr/bin"

# Cache directory for cloned repos
CACHE_DIR="$HOME/.vibecode-cache"
mkdir -p "$CACHE_DIR"

# Detect vibecode codebase location
# Priority: VIBECODE_HOME (local or mounted path), VIBECODE_GIT (git repo), local ~/vibecode
if [ -n "$VIBECODE_HOME" ] && [ -d "$VIBECODE_HOME" ]; then
    CODE_DIR="$VIBECODE_HOME"
    echo "[vibecode] Using codebase from: $CODE_DIR"
elif [ -n "$VIBECODE_GIT" ]; then
    # Clone or update git repo using system git
    REPO_NAME=$(basename "$VIBECODE_GIT" .git)
    CLONE_DIR="$CACHE_DIR/$REPO_NAME"
    
    if [ -d "$CLONE_DIR/.git" ]; then
        echo "[vibecode] Updating codebase from git..."
        cd "$CLONE_DIR"
        git pull
    else
        echo "[vibecode] Cloning codebase from git..."
        git clone "$VIBECODE_GIT" "$CLONE_DIR"
    fi
    CODE_DIR="$CLONE_DIR"
elif [ -d "$HOME/vibecode" ]; then
    CODE_DIR="$HOME/vibecode"
    echo "[vibecode] Using codebase from: $CODE_DIR"
else
    echo "ERROR: Cannot find vibecode codebase"
    echo ""
    echo "Set one of the following:"
    echo "  VIBECODE_HOME=/path/to/vibecode      # Local or mounted directory"
    echo "  VIBECODE_GIT=https://github.com/...  # Git repository URL"
    echo ""
    echo "For network access, mount the remote directory first:"
    echo "  sshfs user@192.168.4.233:/home/user/vibecode ~/vibecode"
    echo "  export VIBECODE_HOME=~/vibecode"
    exit 1
fi

# Bind to all interfaces so app can be accessed from any machine
export HERMES_WEBUI_HOST="0.0.0.0"
export HERMES_WEBUI_PORT="8786"
export HERMES_WEBUI_DEFAULT_WORKSPACE="$HOME/workspace"

cd "$CODE_DIR"

# Start the server in background and open browser
python3 server.py &
SERVER_PID=$!

# Wait for server to be ready
sleep 2

# Open browser
if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "http://localhost:8786"
elif command -v firefox >/dev/null 2>&1; then
    firefox "http://localhost:8786"
elif command -v chromium >/dev/null 2>&1; then
    chromium "http://localhost:8786"
elif command -v google-chrome >/dev/null 2>&1; then
    google-chrome "http://localhost:8786"
else
    echo "[vibecode] Server running at http://localhost:8786"
    echo "[vibecode] Please open your browser manually"
fi

# Wait for server process
wait $SERVER_PID